.DS_Store

# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
*_files/
data/SingleCell/*/cache*/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/


# Processed data files
data/*rds
data/Bulk/uc_conserved*.csv
data/SingleCell/*/R_objects*


# Raw data files
data/SingleCell/Il10KO/expression_matrices*
data/SingleCell/TcellTransfer/expression_matrices*
data/Bulk/mouseKEGG.rds
data/Spatial/cellranger_output


# Tests
scripts/tests
scripts/*.pdf
*donotpublish*
